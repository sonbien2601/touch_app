rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function isSelf(uid) {
      return signedIn() && request.auth.uid == uid;
    }

    function userDoc(uid) {
      return get(/databases/$(database)/documents/users/$(uid));
    }

    function coupleIdOf(uid) {
      return userDoc(uid).data.coupleId;
    }

    function sameCouple(uid) {
      return signedIn()
        && uid != request.auth.uid
        && coupleIdOf(request.auth.uid) != null
        && coupleIdOf(request.auth.uid) == coupleIdOf(uid);
    }

    function isCoupleMember(coupleId) {
      return signedIn()
        && exists(/databases/$(database)/documents/couples/$(coupleId))
        && request.auth.uid in get(/databases/$(database)/documents/couples/$(coupleId)).data.members;
    }

    function invite(code) {
      return get(/databases/$(database)/documents/inviteCodes/$(code));
    }

    function afterCouple(coupleId) {
      return getAfter(/databases/$(database)/documents/couples/$(coupleId));
    }

    function safeUserUpdate(uid) {
      return isSelf(uid)
        && request.resource.data.diff(resource.data).changedKeys()
          .hasOnly(['name', 'avatar', 'online', 'lastSeen', 'fcmToken', 'battery', 'updatedAt'])
        && request.resource.data.uid == resource.data.uid
        && request.resource.data.email == resource.data.email
        && request.resource.data.coupleId == resource.data.coupleId;
    }

    function validPairingUserUpdate(uid) {
      let coupleId = request.resource.data.coupleId;
      let couple = afterCouple(coupleId).data;
      let code = couple.inviteCode;
      return signedIn()
        && request.resource.data.diff(resource.data).changedKeys().hasOnly(['coupleId', 'updatedAt'])
        && resource.data.coupleId == null
        && coupleId is string
        && uid in couple.members
        && request.auth.uid in couple.members
        && (uid == request.auth.uid || invite(code).data.ownerId == uid)
        && getAfter(/databases/$(database)/documents/inviteCodes/$(code)).data.consumedAt != null
        && getAfter(/databases/$(database)/documents/inviteCodes/$(code)).data.consumedBy == request.auth.uid
        && getAfter(/databases/$(database)/documents/inviteCodes/$(code)).data.consumedCoupleId == coupleId;
    }

    function validTouchUserUpdate(uid) {
      return signedIn()
        && request.resource.data.diff(resource.data).changedKeys().hasOnly(['lastTouchAt', 'totalTouch', 'updatedAt'])
        && request.resource.data.uid == resource.data.uid
        && request.resource.data.email == resource.data.email
        && request.resource.data.coupleId == resource.data.coupleId
        && request.resource.data.totalTouch == resource.data.totalTouch + 1
        && (uid == request.auth.uid || sameCouple(uid));
    }

    function validInviteCodeCreate(code) {
      return signedIn()
        && request.resource.id == code
        && request.resource.data.keys().hasOnly(['code', 'ownerId', 'expiredAt', 'consumedAt', 'consumedBy', 'consumedCoupleId', 'createdAt'])
        && request.resource.data.code == code
        && request.resource.data.ownerId == request.auth.uid
        && request.resource.data.consumedAt == null
        && request.resource.data.consumedBy == null
        && request.resource.data.consumedCoupleId == null;
    }

    function validCoupleCreate() {
      let code = request.resource.data.inviteCode;
      return signedIn()
        && request.resource.data.keys().hasOnly(['userA', 'userB', 'members', 'inviteCode', 'createdAt', 'lastTouchAt', 'totalTouch', 'streak', 'longestStreak'])
        && request.auth.uid in request.resource.data.members
        && request.resource.data.members.size() == 2
        && request.resource.data.userA in request.resource.data.members
        && request.resource.data.userB in request.resource.data.members
        && request.resource.data.userA != request.resource.data.userB
        && code is string
        && exists(/databases/$(database)/documents/inviteCodes/$(code))
        && invite(code).data.ownerId in request.resource.data.members
        && invite(code).data.ownerId != request.auth.uid
        && invite(code).data.consumedAt == null
        && request.time < invite(code).data.expiredAt
        && getAfter(/databases/$(database)/documents/inviteCodes/$(code)).data.consumedBy == request.auth.uid
        && getAfter(/databases/$(database)/documents/inviteCodes/$(code)).data.consumedCoupleId == request.resource.id
        && userDoc(request.auth.uid).data.coupleId == null
        && userDoc(invite(code).data.ownerId).data.coupleId == null
        && request.resource.data.totalTouch == 0
        && request.resource.data.streak == 0
        && request.resource.data.longestStreak == 0;
    }

    function validCoupleTouchUpdate() {
      return isCoupleMember(resource.id)
        && request.resource.data.diff(resource.data).changedKeys().hasOnly(['lastTouchAt', 'totalTouch', 'streak', 'longestStreak'])
        && request.resource.data.totalTouch == resource.data.totalTouch + 1;
    }

    function validTouchCreate() {
      return signedIn()
        && request.resource.data.keys().hasOnly(['id', 'coupleId', 'senderId', 'receiverId', 'createdAt', 'device', 'appVersion'])
        && request.resource.data.id == request.resource.id
        && request.resource.data.senderId == request.auth.uid
        && request.resource.data.senderId != request.resource.data.receiverId
        && isCoupleMember(request.resource.data.coupleId)
        && request.resource.data.receiverId in get(/databases/$(database)/documents/couples/$(request.resource.data.coupleId)).data.members;
    }

    match /users/{uid} {
      allow create: if isSelf(uid)
        && request.resource.data.uid == uid
        && request.resource.data.coupleId == null;

      allow read: if isSelf(uid) || sameCouple(uid);

      allow update: if safeUserUpdate(uid) || validPairingUserUpdate(uid) || validTouchUserUpdate(uid);

      allow delete: if false;
    }

    match /couples/{coupleId} {
      allow read: if isCoupleMember(coupleId);
      allow create: if validCoupleCreate();
      allow update: if validCoupleTouchUpdate();
      allow delete: if false;
    }

    match /touches/{touchId} {
      allow read: if signedIn()
        && (resource.data.senderId == request.auth.uid
          || resource.data.receiverId == request.auth.uid)
        && isCoupleMember(resource.data.coupleId);

      allow create: if validTouchCreate();
      allow update, delete: if false;
    }

    match /inviteCodes/{code} {
      allow read: if signedIn();
      allow create: if validInviteCodeCreate(code);
      allow update: if signedIn()
        && resource.data.ownerId != request.auth.uid
        && request.resource.data.diff(resource.data).changedKeys().hasOnly(['consumedAt', 'consumedBy', 'consumedCoupleId'])
        && resource.data.consumedAt == null
        && resource.data.consumedBy == null
        && resource.data.consumedCoupleId == null
        && request.resource.data.consumedAt != null
        && request.resource.data.consumedBy == request.auth.uid
        && getAfter(/databases/$(database)/documents/couples/$(request.resource.data.consumedCoupleId)).data.inviteCode == code
        && resource.data.ownerId in getAfter(/databases/$(database)/documents/couples/$(request.resource.data.consumedCoupleId)).data.members
        && request.auth.uid in getAfter(/databases/$(database)/documents/couples/$(request.resource.data.consumedCoupleId)).data.members;
      allow delete: if false;
    }
  }
}
